            --bg-card: #1a1f21;
            --accent-gold: #f4d03f;
            --accent-teal: #1abc9c;
            --accent-green: #27ae60;
            --accent-red: #e74c3c;
            --text-primary: #e8f4f8;
            --text-secondary: #7f8c8d;
            --border-coherence: #2c3e50;
            --live-pulse: #27ae60;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
            background: var(--bg-primary);
            color: var(--text-primary);
            line-height: 1.6;
            min-height: 100vh;
        }
        
        .live-banner {
            background: linear-gradient(90deg, #27ae60 0%, #1abc9c 100%);
            color: #000;
            text-align: center;
            padding: 0.5rem;
            font-weight: 700;
            letter-spacing: 2px;
            animation: livePulse 2s infinite;
        }
        
        @keyframes livePulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.7; }
        }
        
        .sovereign-header {
            background: var(--bg-secondary);
            border-bottom: 2px solid var(--accent-gold);
            padding: 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .federation-brand {
            display: flex;
            align-items: center;
            gap: 1rem;
        }
        
        .phi-cursor {
            color: var(--accent-gold);
            font-size: 2rem;
            animation: pulse 2s infinite;
        }
        
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        
        .sovereign-title {
            font-size: 1.5rem;
            font-weight: 700;
            letter-spacing: 3px;
        }
        
        .status-indicator {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            background: rgba(39, 174, 96, 0.2);
            border: 1px solid var(--accent-green);
            padding: 0.5rem 1rem;
            border-radius: 4px;
        }
        
        .live-dot {
            width: 8px;
            height: 8px;
            background: var(--live-pulse);
            border-radius: 50%;
            animation: blink 1s infinite;
        }
        
        @keyframes blink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0; }
        }
        
        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 2rem;
        }
        
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(600px, 1fr));
            gap: 2rem;
            margin-top: 2rem;
        }
        
        .infra-card {
            background: var(--bg-card);
            border: 1px solid var(--border-coherence);
            border-radius: 8px;
            padding: 2rem;
            position: relative;
            overflow: hidden;
        }
        
        .infra-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--accent-gold), var(--accent-teal));
        }
        
        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid var(--border-coherence);
        }
        
        .card-title {
            color: var(--accent-gold);
            font-size: 1.2rem;
            letter-spacing: 2px;
            text-transform: uppercase;
        }
        
        .live-badge {
            background: var(--accent-green);
            color: #000;
            padding: 0.25rem 0.75rem;
            border-radius: 2px;
            font-size: 0.75rem;
            font-weight: 700;
        }
        
        .data-table {
            width: 100%;
            border-collapse: collapse;
        }
        
        .data-table tr {
            border-bottom: 1px solid var(--border-coherence);
        }
        
        .data-table tr:last-child {
            border-bottom: none;
        }
        
        .data-table td {
            padding: 1rem 0.5rem;
        }
        
        .data-table .label {
            color: var(--text-secondary);
            font-weight: 500;
            width: 40%;
        }
        
        .data-table .value {
            color: var(--text-primary);
            text-align: right;
            font-weight: 600;
        }
        
        .data-table .value.gold {
            color: var(--accent-gold);
        }
        
        .data-table .value.active {
            color: var(--accent-green);
        }
        
        .data-table .value.pending {
            color: var(--accent-red);
        }
        
        .sub-section {
            margin-top: 1.5rem;
            padding-top: 1.5rem;
            border-top: 1px dashed var(--border-coherence);
        }
        
        .sub-title {
            color: var(--accent-teal);
            font-size: 0.9rem;
            margin-bottom: 1rem;
            letter-spacing: 1px;
        }
        
        .footer {
            background: var(--bg-secondary);
            border-top: 1px solid var(--accent-gold);
            padding: 2rem;
            text-align: center;
            margin-top: 3rem;
            color: var(--text-secondary);
            font-size: 0.875rem;
        }
        
        .sovereign-sig {
            color: var(--accent-gold);
            margin-top: 0.5rem;
            font-weight: 600;
        }
        
        @media (max-width: 768px) {
            .grid {
                grid-template-columns: 1fr;
            }
            .sovereign-header {
                flex-direction: column;
                gap: 1rem;
                text-align: center;
            }
        }
    </style>
</head>
